<p>Hi {{merchantName}},</p>
<p>Unfortunately, a payment or settlement has failed. Please review the details below and contact support if you need assistance.</p>
<div class="detail-box">
  <table>
    <tr><td>Reference</td><td>{{reference}}</td></tr>
    <tr><td>Amount</td><td>{{amount}} {{currency}}</td></tr>
    <tr><td>Reason</td><td>{{reason}}</td></tr>
    <tr><td>Failed At</td><td>{{failedAt}}</td></tr>
  </table>
</div>
<a class="btn" href="{{supportUrl}}">Contact Support</a>
