# Server
PORT=3000
API_PREFIX=api/v1
NODE_ENV=development

# CORS - comma-separated list of trusted frontend origins (production only)
ALLOWED_ORIGINS=https://app.cheesepay.xyz,https://cheesepay.xyz

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_NAME=cheesepay

# JWT
JWT_SECRET=your_jwt_secret_key_min_32_chars
JWT_EXPIRES_IN=7d

# API Keys
API_KEY_SALT=your_api_key_salt

# Stellar
STELLAR_NETWORK=TESTNET
STELLAR_ACCOUNT_SECRET=SXXX...
STELLAR_ACCOUNT_PUBLIC=GXXX...
STELLAR_USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Fiat Settlement Partner
PARTNER_API_URL=https://partner-api.example.com/v1
PARTNER_API_KEY=your_partner_api_key
PARTNER_WEBHOOK_SECRET=your_partner_webhook_secret

# Webhooks
WEBHOOK_SECRET=your_webhook_signing_secret

# Monitoring (Optional)
SENTRY_DSN=https://xxx@sentry.io/xxx
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

OTEL_ENABLED=false
OTEL_SERVICE_NAME=cheesepay-backend
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_TRACE_CONSOLE=false

# Queue retry config (#767)
QUEUE_MAX_RETRIES=5
WEBHOOK_RETRY_SCHEDULE=60000,300000,1800000,7200000,43200000
EMAIL_RETRY_DELAY=300000
EMAIL_MAX_RETRIES=1
SETTLEMENT_RETRY_DELAYS=60000,300000,1800000
STELLAR_MONITOR_RETRY_DELAY=0

# Email (for notifications queue #763)
EMAIL_FROM=noreply@cheesepay.io
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SENDGRID_API_KEY=

# CORS (production only)
ALLOWED_ORIGINS=https://app.cheesepay.io,https://dashboard.cheesepay.io

# Email (Nodemailer — SMTP or SendGrid)
# For SendGrid: set EMAIL_SMTP_HOST=smtp.sendgrid.net, EMAIL_SMTP_USER=apikey, EMAIL_SMTP_PASS=<your_sendgrid_api_key>
# For plain SMTP: set host/port/user/pass for your SMTP server
EMAIL_PROVIDER=smtp
EMAIL_SMTP_HOST=smtp.sendgrid.net
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=apikey
EMAIL_SMTP_PASS=your_sendgrid_api_key_or_smtp_password
EMAIL_FROM=noreply@cheesepay.xyz
EMAIL_FROM_NAME=CheesePay
